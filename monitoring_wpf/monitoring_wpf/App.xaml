<Application x:Class="monitoring_wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- 색상 -->
        <Color x:Key="BgColor">#FF0D0F12</Color>
        <Color x:Key="SurfaceColor">#FF151820</Color>
        <Color x:Key="Surface2Color">#FF1C2030</Color>
        <Color x:Key="BorderColor">#FF252C3A</Color>
        <Color x:Key="TealColor">#FF00D4AA</Color>
        <Color x:Key="TealDimColor">#1600D4AA</Color>
        <Color x:Key="RedColor">#FFFF4455</Color>
        <Color x:Key="RedDimColor">#20FF4455</Color>
        <Color x:Key="AmberColor">#FFF5A623</Color>
        <Color x:Key="AmberDimColor">#20F5A623</Color>
        <Color x:Key="BlueColor">#FF4A9EFF</Color>
        <Color x:Key="BlueDimColor">#164A9EFF</Color>
        <Color x:Key="TextColor">#FFE2E5ED</Color>
        <Color x:Key="TextDimColor">#FF3F4859</Color>
        <Color x:Key="TextMidColor">#FF8892A4</Color>

        <!-- 브러시 -->
        <SolidColorBrush x:Key="BgBrush"       Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush"  Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TealBrush"     Color="{StaticResource TealColor}"/>
        <SolidColorBrush x:Key="TealDimBrush"  Color="{StaticResource TealDimColor}"/>
        <SolidColorBrush x:Key="RedBrush"      Color="{StaticResource RedColor}"/>
        <SolidColorBrush x:Key="RedDimBrush"   Color="{StaticResource RedDimColor}"/>
        <SolidColorBrush x:Key="AmberBrush"    Color="{StaticResource AmberColor}"/>
        <SolidColorBrush x:Key="AmberDimBrush" Color="{StaticResource AmberDimColor}"/>
        <SolidColorBrush x:Key="BlueBrush"     Color="{StaticResource BlueColor}"/>
        <SolidColorBrush x:Key="TextBrush"     Color="{StaticResource TextColor}"/>
        <SolidColorBrush x:Key="TextDimBrush"  Color="{StaticResource TextDimColor}"/>
        <SolidColorBrush x:Key="TextMidBrush"  Color="{StaticResource TextMidColor}"/>

        <!-- 텍스트 스타일 -->
        <Style x:Key="MonoText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style x:Key="DimText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize"   Value="10"/>
        </Style>
        <Style x:Key="MidText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource TextMidBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

        <!-- 카드 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="7"/>
            <Setter Property="Padding"         Value="14,12"/>
        </Style>

        <!-- 긴급정지 버튼 -->
        <Style x:Key="EstopButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource RedDimBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Padding"         Value="0,14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 일반 버튼 -->
        <Style x:Key="CtrlButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface2Brush}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMidBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="0,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource TealDimBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource TealBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TealBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>

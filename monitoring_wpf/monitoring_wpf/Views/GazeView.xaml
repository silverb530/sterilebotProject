<UserControl x:Class="monitoring_wpf.Views.GazeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽: 카메라 + 시선맵 -->
        <StackPanel Grid.Column="0" Margin="0,0,7,0">
            <TextBlock Style="{StaticResource SectionLabel}" Text="OV9281 — 동공 카메라" Margin="0,0,0,8"/>

            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,12">
                <StackPanel>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,7">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="OV9281 IR NoIR · CSI" Style="{StaticResource MidText}"/>
                            <Border DockPanel.Dock="Right" CornerRadius="3" Padding="7,1" Background="{StaticResource TealDimBrush}">
                                <TextBlock Text="60fps" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TealBrush}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    <Border Height="180" Background="#070809">
                        <Grid>
                            <TextBlock Text="1280×800 · MIPI" FontFamily="Consolas" FontSize="9"
                         Foreground="#44FFFFFF" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="9,7"/>
                            <TextBlock x:Name="CamLabel0" Text="cx:640 cy:400" FontFamily="Consolas" FontSize="9"
                         Foreground="#44FFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,9,7"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="시선 위치 맵" Style="{StaticResource DimText}" Margin="0,0,0,8"/>
                    <Border Height="140" Background="#070809" CornerRadius="5"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Canvas x:Name="GazeCanvas" SizeChanged="GazeCanvas_SizeChanged">
                            <Line x:Name="GazeLineH" Stroke="#22FFFFFF" StrokeThickness="1"/>
                            <Line x:Name="GazeLineV" Stroke="#22FFFFFF" StrokeThickness="1"/>
                            <Ellipse x:Name="GazeRing" Width="24" Height="24"
                       Stroke="{StaticResource TealBrush}" StrokeThickness="1" Opacity="0.3"/>
                            <Ellipse x:Name="GazeDot" Width="10" Height="10" Fill="{StaticResource TealBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00D4AA" ShadowDepth="0" BlurRadius="8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Border>
                    <UniformGrid Rows="2" Columns="2" Margin="0,10,0,0">
                        <Border Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="0,0,4,4">
                            <StackPanel>
                                <TextBlock Text="cx (px)" Style="{StaticResource DimText}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="GCx" Text="640" FontFamily="Consolas" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="4,0,0,4">
                            <StackPanel>
                                <TextBlock Text="cy (px)" Style="{StaticResource DimText}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="GCy" Text="400" FontFamily="Consolas" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="→ X (mm)" Style="{StaticResource DimText}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="GRx" Text="0" FontFamily="Consolas" FontSize="20" FontWeight="Medium" Foreground="{StaticResource BlueBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="→ Y (mm)" Style="{StaticResource DimText}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="GRy" Text="0" FontFamily="Consolas" FontSize="20" FontWeight="Medium" Foreground="{StaticResource BlueBrush}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 오른쪽: EAR + Dwell + 긴급정지 -->
        <StackPanel Grid.Column="1" Margin="7,0,0,0">
            <TextBlock Style="{StaticResource SectionLabel}" Text="EAR — 눈 깜빡임" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="눈 종횡비 (Eye Aspect Ratio)" Style="{StaticResource DimText}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="EarVal" Text="0.32" FontFamily="Consolas" FontSize="44"
                     FontWeight="Medium" Foreground="{StaticResource TealBrush}"/>
                    <DockPanel Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left"  Text="0.00" Style="{StaticResource DimText}"/>
                        <TextBlock DockPanel.Dock="Right" Text="0.50" Style="{StaticResource DimText}"/>
                        <TextBlock Text="임계값 0.20" Style="{StaticResource DimText}"
                       Foreground="{StaticResource RedBrush}" HorizontalAlignment="Center"/>
                    </DockPanel>
                    <Grid Height="8" Margin="0,4,0,0">
                        <Border Background="{StaticResource Surface2Brush}" CornerRadius="4"/>
                        <Border x:Name="EarFill" Background="{StaticResource TealBrush}"
                    CornerRadius="4" HorizontalAlignment="Left" Width="80"/>
                        <Border Width="2" Background="{StaticResource RedBrush}" CornerRadius="1"
                    HorizontalAlignment="Left" Margin="60,0,0,0" Height="16" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="EarStatus" Text="정상 — 깜빡임 없음"
                     Style="{StaticResource DimText}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource SectionLabel}" Text="DWELL — 응시 유지" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="응시 지속 시간 (목표 1.5s)" Style="{StaticResource DimText}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="DwellVal" Text="0" FontFamily="Consolas" FontSize="36"
                       FontWeight="Medium" Foreground="{StaticResource AmberBrush}"/>
                        <TextBlock Text="% (1.5s = 100%)" Style="{StaticResource DimText}"
                       VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                    </StackPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"  Text="0s"     Style="{StaticResource DimText}"/>
                        <TextBlock DockPanel.Dock="Right" Text="1.5s ✓" Style="{StaticResource DimText}"/>
                        <TextBlock Text="0.75s" Style="{StaticResource DimText}" HorizontalAlignment="Center"/>
                    </DockPanel>
                    <Grid Height="10" Margin="0,4,0,0">
                        <Border Background="{StaticResource Surface2Brush}" CornerRadius="5"/>
                        <Border x:Name="DwellFill" Background="{StaticResource AmberBrush}"
                    CornerRadius="5" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                    <TextBlock x:Name="DwellStatus" Text="대기 중" Style="{StaticResource DimText}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource SectionLabel}" Text="긴급정지" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Button Content="⬛  긴급정지" Style="{StaticResource EstopButton}" Click="EstopBtn_Click"/>
                    <TextBlock Text="키보드 SPACE · 이중 깜빡임 (0.5s 내 2회)"
                     FontFamily="Consolas" FontSize="10"
                     Foreground="{StaticResource TextDimBrush}"
                     HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

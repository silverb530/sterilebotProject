<UserControl x:Class="monitoring_wpf.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionLabel}"
               Text="C920 — 작업대 조감 (60cm 폴대 고정)" Margin="0,0,0,8"/>
        <Border Style="{StaticResource Card}" Padding="0">
            <StackPanel>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,7">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="Logitech C920 · USB · 1080P" Style="{StaticResource MidText}"/>
                        <Border DockPanel.Dock="Right" CornerRadius="3" Padding="7,1" Background="{StaticResource TealDimBrush}">
                            <TextBlock Text="30fps" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TealBrush}"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border MinHeight="400" Background="#070809">
                    <Grid>
                        <TextBlock Text="작업대 전체 조감" FontFamily="Consolas" FontSize="9"
                       Foreground="#44FFFFFF" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="9,7"/>
                        <TextBlock Text="보조 카메라" FontFamily="Consolas" FontSize="9"
                       Foreground="#44FFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,9,7"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

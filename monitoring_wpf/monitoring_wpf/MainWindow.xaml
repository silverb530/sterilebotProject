<Window x:Class="monitoring_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:monitoring_wpf.Views"
        Title="SterileBot Monitor" Height="800" Width="1280"
        WindowState="Maximized"
        Background="{StaticResource BgBrush}">

    <DockPanel LastChildFill="True">

        <!-- TOP BAR -->
        <Border DockPanel.Dock="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1" Padding="20,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 로고 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Medium"
                     Foreground="{StaticResource TealBrush}" Text="STERILE"/>
                    <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Medium"
                     Foreground="{StaticResource TextDimBrush}" Text="BOT"/>
                </StackPanel>

                <!-- 연결 상태 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="ConnDot" Width="7" Height="7" Margin="0,0,8,0" Fill="{StaticResource AmberBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ConnLabel" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AmberBrush}" Text="FLASK 연결 중..."/>
                </StackPanel>
                
                
                

                <!-- FSM + 시계 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border x:Name="FsmBadge" CornerRadius="4" Padding="13,4" Margin="0,0,14,0"
                  Background="{StaticResource TealDimBrush}"
                  BorderBrush="{StaticResource TealBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="FsmDot" Width="6" Height="6" Margin="0,0,7,0"
                       Fill="{StaticResource TealBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FsmText" FontFamily="Consolas" FontSize="11"
                         FontWeight="Medium" Foreground="{StaticResource TealBrush}" Text="IDLE"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="ClockText" FontFamily="Consolas" FontSize="13"
                     Foreground="{StaticResource TextMidBrush}" Text="--:--:--" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOG STRIP (하단 고정) -->
        <Border DockPanel.Dock="Bottom"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0" Height="148">
            <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="14,6">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource TextDimBrush}" Text="시스템 로그" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="전체" Tag="all"  Click="LogFilter_Click" Style="{StaticResource CtrlButton}" Margin="0,0,4,0" Padding="9,2"/>
                            <Button Content="OK"   Tag="ok"   Click="LogFilter_Click" Style="{StaticResource CtrlButton}" Margin="0,0,4,0" Padding="9,2"/>
                            <Button Content="INFO" Tag="info" Click="LogFilter_Click" Style="{StaticResource CtrlButton}" Margin="0,0,4,0" Padding="9,2"/>
                            <Button Content="WARN" Tag="warn" Click="LogFilter_Click" Style="{StaticResource CtrlButton}" Margin="0,0,4,0" Padding="9,2"/>
                            <Button Content="ERR"  Tag="err"  Click="LogFilter_Click" Style="{StaticResource CtrlButton}" Margin="0,0,12,0" Padding="9,2"/>
                            <Button Content="지우기" Click="ClearLog_Click" Style="{StaticResource CtrlButton}" Padding="8,2"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="14,4">
                    <ItemsControl x:Name="LogList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,1">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Ts}" FontFamily="Consolas" FontSize="10"
                             Foreground="{StaticResource TextDimBrush}" Width="60" VerticalAlignment="Center"/>
                                    <Border DockPanel.Dock="Left" CornerRadius="3" Padding="4,0" Margin="0,0,10,0"
                          Background="{Binding TagBg}" Width="38">
                                        <TextBlock Text="{Binding TagText}" FontFamily="Consolas" FontSize="10"
                               Foreground="{Binding TagFg}" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Msg}" FontFamily="Consolas" FontSize="10"
                             Foreground="{StaticResource TextMidBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- TAB BAR -->
        <Border DockPanel.Dock="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                <Button x:Name="TabGaze"     Content="👁  동공·시선·센서"    Click="Tab_Click" Tag="gaze"     Style="{StaticResource CtrlButton}" Padding="22,9" Margin="0,0,2,0"/>
                <Button x:Name="TabGripper"  Content="🤖  그리퍼·로봇·제어"  Click="Tab_Click" Tag="gripper"  Style="{StaticResource CtrlButton}" Padding="22,9" Margin="0,0,2,0"/>
                <Button x:Name="TabOverview" Content="📷  작업대 조감"        Click="Tab_Click" Tag="overview" Style="{StaticResource CtrlButton}" Padding="22,9"/>
            </StackPanel>
        </Border>

        <!-- 탭 콘텐츠 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16,14">
                <views:GazeView     x:Name="GazeView"     Visibility="Visible"/>
                <views:GripperView  x:Name="GripperView"  Visibility="Collapsed"/>
                <views:OverviewView x:Name="OverviewView" Visibility="Collapsed"/>
            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
